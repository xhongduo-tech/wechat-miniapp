/* 全局背景 */
page {
  background-color: #f6f6f6;
  min-height: 100vh;
}

.container {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 60rpx;
}

/* 1. 顶部头图 */
.header-img {
  width: 100%;
  display: block; /* 消除底部间隙 */
  /* 如果图片背景是白色的，可以加个阴影让它更有层次 */
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
}

/* 2. 列表区域 */
.list-area {
  width: 100%;
  padding: 30rpx;
  box-sizing: border-box;
  margin-top: -20rpx; /* 稍微向上叠一点，增加层次感（可选） */
}

/* 卡片样式 */
.team-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  display: flex;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  /* 增加一点点击态的动效准备 */
  transition: all 0.2s;
}

/* 左侧红条 */
.card-bar {
  width: 10rpx;
  background-color: #ff4d4f; /* 新年红 */
}

/* 内容区 */
.card-content {
  flex: 1;
  padding: 24rpx 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.role-title {
  font-size: 28rpx;
  color: #ff4d4f; /* 标题用红色呼应 */
  font-weight: bold;
  margin-bottom: 12rpx;
}

.member-names {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.5;
}

/* 3. 底部致谢 */
.footer-thanks {
  margin-top: 40rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer-thanks text {
  font-size: 24rpx;
  color: #888;
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}

.copyright {
  font-size: 20rpx;
  color: #ccc;
}